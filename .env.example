# .env.example — copy to .env and fill in real values
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
POSTGRES_DB=taskdb
POSTGRES_USER=taskuser
POSTGRES_PASSWORD=taskpass
REDIS_URL=redis://redis:6379/0
DJANGO_SETTINGS_MODULE=config.settings.dev

CELERY_TASK_ALWAYS_EAGER=False

# Optional overrides (defaults work for Docker Compose)
# DATABASE_HOST=db
# DATABASE_PORT=5432
# CORS_ALLOWED_ORIGINS=http://localhost:5173 http://localhost:3000

# Email — SMTP configuration
# In dev, emails are printed to console (dev.py overrides EMAIL_BACKEND).
# In prod, set DJANGO_SETTINGS_MODULE=config.settings.prod and fill these in.
NODEMAILER_HOST=smtp.gmail.com
NODEMAILER_PORT=587
NODEMAILER_EMAIL=your-email@gmail.com
NODEMAILER_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@taskapp.local